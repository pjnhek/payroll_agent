DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
EXTRACTION_MODEL=deepseek-v4-flash
EXTRACTION_BASE_URL=https://api.deepseek.com
EXTRACTION_API_KEY=sk-your-deepseek-key-here
DRAFT_MODEL=moonshot-v1-8k
DRAFT_BASE_URL=https://api.moonshot.ai/v1
DRAFT_API_KEY=sk-your-moonshot-key-here
TAX_YEAR=2026
ALLOW_LIVE_LLM=0

# ── Resend email provider (Phase 6) ───────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
RESEND_FROM_ADDR=onboarding@resend.dev

# REPLY-TO TOPOLOGY: set to your inbound .resend.app address (the address wired to
# the Resend inbound webhook). Client replies are directed here, not to RESEND_FROM_ADDR.
# Leave empty to omit Reply-To from outbound sends.
RESEND_REPLY_TO=payroll@jiodnel.resend.app
